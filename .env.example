# Use HTTPS for real iPhone testing (ATS blocks non-HTTPS endpoints).
# Localhost HTTP is only for emulator/simulator development.
EXPO_PUBLIC_API_URL=https://api.your-domain.com
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_ONESIGNAL_APP_ID=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_IOS_PUSH_ENABLED=false
EXPO_IOS_ONESIGNAL_ENABLED=false
GOOGLE_MAPS_API_KEY=

# Optional build flag for local Android testing only.
EXPO_ANDROID_USES_CLEARTEXT_TRAFFIC=false
